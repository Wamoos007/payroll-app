{
  "name": "payroll-app",
  "version": "2.6.0",
  "description": "AMIEM Payroll Desktop Application",
  "main": "main.js",
  "author": "Waleed Moos",
  "license": "ISC",
  "postinstall": "electron-rebuild -f -w better-sqlite3",
  "scripts": {
    "rebuild-native": "electron-rebuild -f -w better-sqlite3",
    "dev": "npm run rebuild-native && concurrently \"npm run client\" \"wait-on http://localhost:3002 && npm run electron-dev\"",
    "server": "cross-env NODE_ENV=development PORT=3001 node server/app.js",
    "client": "cross-env PORT=3002 REACT_APP_API_BASE_URL=http://localhost:3003 npm start --prefix client",
    "electron-dev": "cross-env NODE_ENV=development SERVER_PORT=3003 CLIENT_DEV_URL=http://localhost:3002 electron .",
    "build-client": "cd client && npm run build",
    "build": "npm run build-client && cross-env NODE_ENV=production electron-builder --config.win.signAndEditExecutable=false",
    "build:win": "npm run build-client && cross-env NODE_ENV=production electron-builder --win --config.win.signAndEditExecutable=false",
    "start": "cross-env NODE_ENV=production electron ."
  },
  "dependencies": {
    "@blackglory/better-sqlite3-migrations": "^0.1.20",
    "better-sqlite3": "^12.8.0",
    "cors": "^2.8.5",
    "csv-parse": "^6.1.0",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3",
    "express": "^4.18.2",
    "multer": "^2.0.2",
    "nodemailer": "^8.0.1",
    "pdfkit": "^0.17.2"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.2",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "electron": "25.9.8",
    "electron-builder": "^24.0.0",
    "electron-rebuild": "^3.2.9",
    "wait-on": "^8.0.5"
  },
  "build": {
    "appId": "com.payroll.app",
    "productName": "AMIEM Payroll",
    "artifactName": "${productName}-Setup-${version}.${ext}",
    "asar": true,
    "extraResources": [
      {
        "from": "assets/icon.ico",
        "to": "icon.ico"
      }
    ],
    "files": [
      "**/*"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "Wamoos007",
        "repo": "payroll-app"
      }
    ],
    "nsis": {
      "include": "assets/installer.nsh"
    },
    "win": {
      "icon": "assets/icon.ico",
      "target": "nsis"
    }
  }
}
